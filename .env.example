# OpenAI Api Key and Logfire Token
OPENAI_API_KEY=sk-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
# Optional: required only when running with --dev
LOGFIRE_TOKEN=your_logfire_token_here

# MCP
MCP_URL=http://localhost:8051

# Neo4j — optional; only needed when USE_KNOWLEDGE_GRAPH=true in mcp.env.
# Local Neo4j via Docker Compose:  docker compose up -d neo4j
# (also set NEO4J_USER / NEO4J_PASSWORD in mcp.env to match)
NEO4J_URI=bolt://localhost:7687

# kicad
# Pull the prebuilt image with:
# docker pull ghcr.io/shaurya-sethi/circuitron-kicad:latest
KICAD_IMAGE=ghcr.io/shaurya-sethi/circuitron-kicad:latest


