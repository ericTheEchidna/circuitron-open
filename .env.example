# LLM Provider — set ONE of the following depending on CIRCUITRON_PROVIDER
# CIRCUITRON_PROVIDER=anthropic   -> set ANTHROPIC_API_KEY
# CIRCUITRON_PROVIDER=openai-agents -> set OPENAI_API_KEY
CIRCUITRON_PROVIDER=anthropic
ANTHROPIC_API_KEY=sk-ant-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
# OPENAI_API_KEY=sk-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Optional: Logfire tracing (only needed with --dev)
# LOGFIRE_TOKEN=your_logfire_token_here

# MCP server (local stack via docker compose)
MCP_URL=http://localhost:8051

# KiCad runner image
KICAD_IMAGE=ghcr.io/shaurya-sethi/circuitron-kicad:latest
