# .env.local.example — Circuitron fully-local configuration
#
# Copy to .env and fill in the two required values marked <REQUIRED>.
# Everything else has working defaults for a local stack.
#
# Prerequisites:
#   - Ollama running locally or on a remote host (https://ollama.com)
#   - PostgreSQL + pgvector on miso (or any reachable host)
#   - docker compose up -d  (starts Neo4j + MCP server)

# ── LLM provider: Ollama ─────────────────────────────────────────────────────
CIRCUITRON_PROVIDER=ollama

# Ollama host — use http://localhost:11434 if running on this machine,
# or http://<hostname>:11434 for a remote server (e.g. miso).
OLLAMA_BASE_URL=http://localhost:11434   # <REQUIRED if Ollama is on a remote host>

# ── MCP server ───────────────────────────────────────────────────────────────
MCP_URL=http://localhost:8051

# ── Neo4j (started by docker compose) ────────────────────────────────────────
# Circuitron probes this at startup to give a clear error if Neo4j isn't up.
NEO4J_URI=bolt://localhost:7687

# ── Docker image overrides ────────────────────────────────────────────────────
# MCP_IMAGE is read by docker-compose.yml.  Use the patched local image when
# connecting to miso Postgres (DATABASE_URL path); use the upstream image for
# the Supabase cloud path.
MCP_IMAGE=circuitron-mcp-local

# KiCad image used by Circuitron for schematic / PCB generation.
KICAD_IMAGE=ghcr.io/shaurya-sethi/circuitron-kicad:latest

# ── Logfire tracing (optional) ────────────────────────────────────────────────
# Leave commented out to disable Logfire tracing.
# LOGFIRE_TOKEN=

# ── Note: OpenAI key ─────────────────────────────────────────────────────────
# The MCP server uses OpenAI for embeddings (text-embedding-3-small) even when
# Circuitron uses Ollama for its own agents.  Set OPENAI_API_KEY in mcp.env.
# You do NOT need to set it here unless you also want cloud fallback for agents.
# OPENAI_API_KEY=
