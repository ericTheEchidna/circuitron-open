# Local MCP server config
TRANSPORT=sse
HOST=0.0.0.0
PORT=8051

# Ollama — running on miso (host machine), reachable from inside the container
OLLAMA_URL=http://host.docker.internal:11434
EMBED_MODEL=nomic-embed-text
LLM_MODEL=qwen2.5-coder:7b

# RAG feature flags
USE_RERANKING=false
LLM_MAX_CONCURRENCY=2

# PostgreSQL + pgvector — running on miso
# Adjust port/credentials to match your miso pgvector instance
POSTGRES_URL=postgresql://captain:memex2026@host.docker.internal:5433/circuitron
