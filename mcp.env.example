# ── MCP server transport ─────────────────────────────────────────────────────
TRANSPORT=sse
HOST=0.0.0.0
PORT=8051

# ── OpenAI (required for embeddings and RAG reranking) ───────────────────────
OPENAI_API_KEY=<your OpenAI API key>
MODEL_CHOICE=gpt-5-nano

# ── RAG feature flags ─────────────────────────────────────────────────────────
USE_CONTEXTUAL_EMBEDDINGS=true
USE_HYBRID_SEARCH=true
USE_AGENTIC_RAG=true
USE_RERANKING=true
USE_KNOWLEDGE_GRAPH=true
LLM_MAX_CONCURRENCY=2
LLM_REQUEST_DELAY=0.5

# ── Vector store — choose ONE of the two paths below ─────────────────────────

# ── Local path (pgvector on your own Postgres — no Supabase account needed) ──
# Prerequisites:
#   1. Build the patched MCP image:  docker build -t circuitron-mcp-local ./mcp
#   2. Run setup_pgvector_local.sql against your Postgres database once.
#   3. Use the patched image in your docker run command (see SETUP.md).
#
# DATABASE_URL=postgresql://<user>:<password>@<host>:5432/<dbname>

# ── Cloud path (Supabase) ─────────────────────────────────────────────────────
# SUPABASE_URL=<your Supabase project URL>
# SUPABASE_SERVICE_KEY=<your Supabase service_role key>

# Uncomment exactly one block above (DATABASE_URL OR SUPABASE_URL+KEY).

# ── Neo4j knowledge graph (required for USE_KNOWLEDGE_GRAPH=true) ────────────
# Cloud:  use the AuraDB URI from neo4j.com/cloud/aura
# Local:  bolt://host.docker.internal:7687
NEO4J_URI=<your Neo4j URI>
NEO4J_USER=<your Neo4j username>
NEO4J_PASSWORD=<your Neo4j password>
