# mcp.env.local.example — MCP server config for local pgvector + local Neo4j
#
# Copy to mcp.env and fill in the values marked <REQUIRED>.
# Use this file together with .env.local.example for a fully local stack.
#
# Prerequisites:
#   1. Build the patched MCP image:
#      docker build -t circuitron-mcp-local ./mcp
#   2. Apply the schema to your Postgres database (once):
#      psql -U <user> -d circuitron -f setup_pgvector_local.sql
#   3. Start services:
#      docker compose up -d

# ── MCP transport ─────────────────────────────────────────────────────────────
TRANSPORT=sse
HOST=0.0.0.0
PORT=8051

# ── OpenAI (required for embeddings even when using Ollama for agents) ────────
OPENAI_API_KEY=<your OpenAI API key>   # <REQUIRED>
MODEL_CHOICE=gpt-5-nano                # used for contextual chunk summarisation

# ── RAG feature flags ─────────────────────────────────────────────────────────
USE_CONTEXTUAL_EMBEDDINGS=true
USE_HYBRID_SEARCH=true
USE_AGENTIC_RAG=true
USE_RERANKING=true
USE_KNOWLEDGE_GRAPH=true
LLM_MAX_CONCURRENCY=2
LLM_REQUEST_DELAY=0.5

# ── Vector store: local Postgres + pgvector ───────────────────────────────────
# Point at your miso (or any pgvector-enabled) Postgres instance.
# Run setup_pgvector_local.sql first to create tables and functions.
DATABASE_URL=postgresql://<user>:<password>@<miso-host>:5432/circuitron   # <REQUIRED>

# ── Neo4j: Docker Compose service ─────────────────────────────────────────────
# When MCP server runs via docker compose, Neo4j is reachable at hostname "neo4j".
# If running the MCP server outside compose, use bolt://localhost:7687 instead.
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=circuitron   # must match NEO4J_PASSWORD in .env / docker-compose.yml
